  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:release": "vite build --mode production",
    "tauri": "tauri",
    "tauri:dev": "./scripts/dev.sh",
    "tauri:build": "tauri build",
    "format": "prettier --write '**/*.{js,json,css,md,ts,tsx,html}'",
    "format:check": "prettier --check '**/*.{js,json,css,md,ts,tsx,html}'",
    "format:files": "prettier --write",
    "lint": "eslint --max-warnings 0 --ignore-path .gitignore --ignore-path .eslintignore \"**/*.js\" \"**/*.ts\" \"**/*.tsx\"",
    "lint:fix": "npm run lint -- --fix --cache",
    "prepare": "husky install",
    "test:tauri": "bash testing/tauri/run-tests.sh",
    "test:tauri:quick": "bash testing/tauri/run-tests.sh --quick",
    "test:tauri:oca": "bash testing/tauri/tests/functional/22-oca-service.sh && bash testing/tauri/tests/functional/23-oca-auth-flow.sh && bash testing/tauri/tests/functional/24-oca-chat-ui.sh && bash testing/tauri/tests/functional/25-oca-streaming.sh",
    "test:tauri:docs": "bash testing/tauri/tests/functional/26-docx-edit.sh && bash testing/tauri/tests/functional/27-xlsx-edit.sh && bash testing/tauri/tests/functional/28-pptx-edit.sh && bash testing/tauri/tests/functional/29-document-llm.sh"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "engines": {
    "node": ">=16.9.1"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "overrides": {
    "@types/minimatch@6.0.0": "5.1.2"
  }
}
