{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "blink",
  "version": "0.1.0",
  "identifier": "com.blink.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../web"
  },
  "app": {
    "windows": [
      {
        "title": "blink",
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "binaries/*"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://updates.blink.app/blink/{{target}}/{{arch}}/{{current_version}}"
      ],
      "pubkey": ""
    }
  }
}
