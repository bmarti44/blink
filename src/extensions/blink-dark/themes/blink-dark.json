  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#697778",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["keyword", "storage.type", "storage.modifier"],
      "settings": {
        "foreground": "#c74634"
      }
    },
    {
      "scope": ["string", "string.quoted"],
      "settings": {
        "foreground": "#f1b13f"
      }
    },
    {
      "scope": ["constant.numeric", "constant.language"],
      "settings": {
        "foreground": "#c2d4d4"
      }
    },
    {
      "scope": ["entity.name.type", "entity.name.class", "support.type"],
      "settings": {
        "foreground": "#c74634"
      }
    },
    {
      "scope": ["entity.name.function", "support.function"],
      "settings": {
        "foreground": "#c2d4d4"
      }
    },
    {
      "scope": ["variable", "variable.other"],
      "settings": {
        "foreground": "#f1efed"
      }
    },
    {
      "scope": ["variable.parameter"],
      "settings": {
        "foreground": "#c2d4d4"
      }
    },
    {
      "scope": ["constant.other", "variable.other.constant"],
      "settings": {
        "foreground": "#c74634"
      }
    },
    {
      "scope": ["entity.name.tag", "punctuation.definition.tag"],
      "settings": {
        "foreground": "#c74634"
      }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#f1b13f"
      }
    },
    {
      "scope": ["string.quoted.double.html", "string.quoted.single.html"],
      "settings": {
        "foreground": "#c2d4d4"
      }
    },
    {
      "scope": ["punctuation", "meta.brace"],
      "settings": {
        "foreground": "#697778"
      }
    },
    {
      "scope": ["keyword.operator"],
      "settings": {
        "foreground": "#c74634"
      }
    },
    {
      "scope": ["meta.decorator", "punctuation.decorator"],
      "settings": {
        "foreground": "#f1b13f"
      }
    },
    {
      "scope": ["support.class", "support.type.property-name"],
      "settings": {
        "foreground": "#c2d4d4"
      }
    },
    {
      "scope": ["markup.heading"],
      "settings": {
        "foreground": "#c74634",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.bold"],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.italic"],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["markup.inline.raw", "markup.fenced_code"],
      "settings": {
        "foreground": "#f1b13f"
      }
    },
    {
      "scope": ["markup.quote"],
      "settings": {
        "foreground": "#697778",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["markup.list"],
      "settings": {
        "foreground": "#c2d4d4"
      }
    },
    {
      "scope": ["markup.underline.link"],
      "settings": {
        "foreground": "#c74634"
      }
    }
  ]
}
