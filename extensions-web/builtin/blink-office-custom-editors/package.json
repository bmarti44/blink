{
  "name": "blink-office-custom-editors-web",
  "publisher": "blink",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.90.0"
  },
  "activationEvents": [
    "onCustomEditor:blink.docxBinary",
    "onCustomEditor:blink.xlsxBinary",
    "onCustomEditor:blink.pptxBinary"
  ],
  "contributes": {
    "customEditors": [
      {
        "viewType": "blink.docxBinary",
        "displayName": "Blink DOCX Editor",
        "selector": [
          {
            "filenamePattern": "*.docx"
          }
        ],
        "priority": "default"
      },
      {
        "viewType": "blink.xlsxBinary",
        "displayName": "Blink XLSX Editor",
        "selector": [
          {
            "filenamePattern": "*.xlsx"
          }
        ],
        "priority": "default"
      },
      {
        "viewType": "blink.pptxBinary",
        "displayName": "Blink PPTX Editor",
        "selector": [
          {
            "filenamePattern": "*.pptx"
          }
        ],
        "priority": "default"
      }
    ]
  }
}
